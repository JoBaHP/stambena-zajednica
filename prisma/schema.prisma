generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(RESIDENT)
  phone     String?
  unit      String?  // broj stana npr. "12", "PP1"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  announcements Announcement[]
  polls         Poll[]
  votes         Vote[]
  transactions  Transaction[]
}

enum Role {
  MANAGER
  RESIDENT
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── FINANSIJE ───────────────────────────────────────────────────────────────

model TransactionCategory {
  id           String        @id @default(cuid())
  name         String        @unique
  type         CategoryType
  color        String        @default("#6366f1")
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

enum CategoryType {
  INCOME
  EXPENSE
}

model Transaction {
  id           String               @id @default(cuid())
  type         TransactionType
  amount       Decimal              @db.Decimal(10, 2)
  description  String
  date         DateTime             @db.Date
  categoryId   String?
  category     TransactionCategory? @relation(fields: [categoryId], references: [id])
  referenceNum String?
  notes        String?
  documents    Document[]
  createdById  String
  createdBy    User                 @relation(fields: [createdById], references: [id])
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ─── PP INSPEKCIJE ───────────────────────────────────────────────────────────

model PPInspection {
  id             String           @id @default(cuid())
  title          String
  inspectionDate DateTime         @db.Date
  nextDueDate    DateTime?        @db.Date
  result         InspectionResult
  inspector      String?
  notes          String?
  documents      Document[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

enum InspectionResult {
  PASSED
  FAILED
  CONDITIONAL
}

// ─── INVESTICIJE ─────────────────────────────────────────────────────────────

model Investment {
  id          String           @id @default(cuid())
  title       String
  description String?
  budget      Decimal          @db.Decimal(10, 2)
  spent       Decimal          @default(0) @db.Decimal(10, 2)
  status      InvestmentStatus @default(PLANNED)
  startDate   DateTime?        @db.Date
  endDate     DateTime?        @db.Date
  documents   Document[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum InvestmentStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── DOKUMENTI ───────────────────────────────────────────────────────────────

model Document {
  id             String        @id @default(cuid())
  name           String
  url            String
  size           Int?
  mimeType       String?
  transactionId  String?
  transaction    Transaction?  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  ppInspectionId String?
  ppInspection   PPInspection? @relation(fields: [ppInspectionId], references: [id], onDelete: Cascade)
  investmentId   String?
  investment     Investment?   @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  announcementId String?
  announcement   Announcement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
}

// ─── KONTAKTI ───────────────────────────────────────────────────────────────

model Contact {
  id        String          @id @default(cuid())
  name      String
  phone     String
  category  ContactCategory
  note      String?
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

enum ContactCategory {
  EMERGENCY
  MANAGEMENT
  MAINTENANCE
}

// ─── OBAVESTENJA ────────────────────────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  priority    Priority  @default(NORMAL)
  isPinned    Boolean   @default(false)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  documents   Document[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum Priority {
  NORMAL
  URGENT
}

// ─── GLASANJE ────────────────────────────────────────────────────────────────

model Poll {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      PollStatus @default(DRAFT)
  startsAt    DateTime?
  endsAt      DateTime?
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  options     PollOption[]
  votes       Vote[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum PollStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text   String
  votes  Vote[]
}

model Vote {
  id       String     @id @default(cuid())
  pollId   String
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId String
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voterId  String
  voter    User       @relation(fields: [voterId], references: [id])
  votedAt  DateTime   @default(now())

  @@unique([pollId, voterId])
}
